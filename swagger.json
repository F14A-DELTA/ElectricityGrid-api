                                  "type": "string"
                                },
                                "label": {
                                  "type": "string"
                                },
                                "power_mw": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "proportion_pct": {
                                  "type": "number",
                                  "nullable": true
