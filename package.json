{
  "name": "seng3011-api",
  "version": "1.0.0",
  "description": "Event-driven API for Australian electricity market data.",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "backfill:raw": "node -r dotenv/config dist/scripts/backfill-raw.js",
    "backfill:rollups": "node -r dotenv/config dist/scripts/build-rollups-local.js",
    "backfill:upload": "node -r dotenv/config dist/scripts/upload-backfill.js",
    "test": "vitest run --exclude src/tests/e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude src/tests/e2e",
    "test:e2e": "vitest run src/tests/e2e",
    "lint": "eslint . -f json -o lint-report.json",
    "generate:report": "node scripts/generate-report.js",
    "swagger:generate": "npx tsc && node dist/src/generate-swagger.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "openelectricity": "^0.7.1-0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "jest-junit": "^16.0.0",
    "markdown-pdf": "^11.0.0",
    "pdfkit": "^0.18.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
