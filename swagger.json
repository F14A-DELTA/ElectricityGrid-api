                                      },
                                      "total_energy_mwh": {
                                        "type": "number",
                                        "nullable": true
                                      }
                                    }
                                  }
                                },
                                "loads": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "fueltech": {
                                        "type": "string"
                                      },
                                      "label": {
                                        "type": "string"
                                      },
                                      "power_mw": {
                                        "type": "number",
                                        "nullable": true
                                      },
                                      "proportion_pct": {
                                        "type": "number",
                                        "nullable": true
                                      },
                                      "price_dollar_per_mwh": {
