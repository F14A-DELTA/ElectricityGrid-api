          "200": {
            "description": "Price and demand for all regions",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Price and demand for all regions",
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "updated_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
