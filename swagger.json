                                },
                                "label": {
                                  "type": "string"
                                },
                                "power_mw": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "proportion_pct": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "price_dollar_per_mwh": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "total_energy_mwh": {
                                  "type": "number",
                                  "nullable": true
                                }
                              }
                            }
                          },
                          "curtailment": {
