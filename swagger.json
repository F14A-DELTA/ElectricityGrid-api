    "/v1/stats": {
      "get": {
        "summary": "Aggregated network statistics over a time range",
        "tags": [
          "Historical Data"
        ],
        "description": "Returns min/max statistics for demand, renewables percentage, and price. Note: 24h range is not supported — use /v1/history instead.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "NEM",
                "WEM"
              ],
              "default": "NEM"
            },
            "in": "query",
            "name": "network",
            "required": false,
            "description": "Network to query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "7d",
                "30d",
                "90d"
              ],
              "default": "7d"
            },
            "in": "query",
            "name": "range",
            "required": false,
            "description": "Time range (24h not supported for stats)"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "NSW1",
                "QLD1",
                "VIC1",
                "SA1",
                "TAS1",
                "WEM"
              ]
            },
            "in": "query",
            "name": "region",
            "required": false,
            "description": "Optional — filter to a specific region"
          }
        ],
        "responses": {
          "200": {
            "description": "Network statistics",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Network statistics",
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "updated_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "demand_mw": {
                          "type": "object",
                          "properties": {
                            "min": {
                              "type": "object",
                              "properties": {
                                "value": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "timestamp": {
                                  "type": "string",
                                  "nullable": true
                                }
                              }
                            },
                            "max": {
                              "type": "object",
                              "properties": {
                                "value": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "timestamp": {
                                  "type": "string",
                                  "nullable": true
                                }
                              }
                            }
                          }
                        },
                        "renewables_pct": {
                          "type": "object",
                          "properties": {
                            "min": {
                              "type": "object",
                              "properties": {
                                "value": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "timestamp": {
                                  "type": "string",
                                  "nullable": true
                                }
                              }
                            },
                            "max": {
                              "type": "object",
                              "properties": {
                                "value": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "timestamp": {
                                  "type": "string",
                                  "nullable": true
                                }
                              }
                            }
                          }
                        },
                        "price": {
                          "type": "object",
                          "properties": {
                            "min": {
                              "type": "object",
                              "properties": {
                                "value": {
                                  "type": "number",
                                  "nullable": true
                                },
                                "timestamp": {
                                  "type": "string",
